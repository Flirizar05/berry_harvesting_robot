<?xml version="1.0"?>
<!--
  Elfin 3 URDF adapted for the berry harvesting robot project.
  Includes RG2-FT gripper integration and rg2ft_grasp_point.
-->
<robot name="elfin3">
  <!-- ================== ELFIN ARM ================== -->
  <link name="world"/>

  <joint name="world_base" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="world"/>
    <child link="elfin_base_link"/>
  </joint>

  <link name="elfin_base_link"/>

  <joint name="elfin_base_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
